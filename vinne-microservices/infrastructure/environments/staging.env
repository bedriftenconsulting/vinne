# Staging Environment Configuration
ENVIRONMENT=staging

# JWT Configuration
JWT_SECRET=${STAGING_JWT_SECRET}
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Database Configuration (dedicated instances)
ADMIN_DATABASE_HOST=staging-admin-postgres.randco.com.gh
AGENT_DATABASE_HOST=staging-agent-postgres.randco.com.gh
PLAYER_DATABASE_HOST=staging-player-postgres.randco.com.gh
DATABASE_PORT=5432

# Redis Configuration
ADMIN_REDIS_HOST=staging-admin-redis.randco.com.gh
AGENT_REDIS_HOST=staging-agent-redis.randco.com.gh
PLAYER_REDIS_HOST=staging-player-redis.randco.com.gh
REDIS_PORT=6379

# Kafka Configuration
KAFKA_BROKERS=staging-kafka-0.randco.com.gh:9092,staging-kafka-1.randco.com.gh:9092,staging-kafka-2.randco.com.gh:9092

# Jaeger Configuration
TRACING_JAEGER_ENDPOINT=http://staging-jaeger-collector.randco.com.gh:14268/api/traces
TRACING_SAMPLE_RATE=0.05

# API Gateway
APOLLO_ROUTER_URL=https://staging-api.randco.com.gh

# Feature Flags
ENABLE_MFA=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true

# Rate Limiting
RATE_LIMIT_REQUESTS=500
RATE_LIMIT_WINDOW=1m

# Log Level
LOGGING_LEVEL=info

# CORS Settings
CORS_ALLOWED_ORIGINS=https://staging.randco.com.gh,https://staging-admin.randco.com.gh
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization