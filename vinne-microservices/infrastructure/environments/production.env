# Production Environment Configuration
ENVIRONMENT=production

# JWT Configuration
JWT_SECRET=${PROD_JWT_SECRET}
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Database Configuration (HA with read replicas)
ADMIN_DATABASE_HOST=prod-admin-postgres.randco.com.gh
ADMIN_DATABASE_READ_REPLICAS=prod-admin-postgres-read-1.randco.com.gh,prod-admin-postgres-read-2.randco.com.gh
AGENT_DATABASE_HOST=prod-agent-postgres.randco.com.gh
AGENT_DATABASE_READ_REPLICAS=prod-agent-postgres-read-1.randco.com.gh,prod-agent-postgres-read-2.randco.com.gh
PLAYER_DATABASE_HOST=prod-player-postgres.randco.com.gh
PLAYER_DATABASE_READ_REPLICAS=prod-player-postgres-read-1.randco.com.gh,prod-player-postgres-read-2.randco.com.gh
DATABASE_PORT=5432

# Redis Configuration (Redis Cluster)
REDIS_CLUSTER_NODES=prod-redis-0.randco.com.gh:6379,prod-redis-1.randco.com.gh:6379,prod-redis-2.randco.com.gh:6379

# Kafka Configuration (5 nodes)
KAFKA_BROKERS=prod-kafka-0.randco.com.gh:9092,prod-kafka-1.randco.com.gh:9092,prod-kafka-2.randco.com.gh:9092,prod-kafka-3.randco.com.gh:9092,prod-kafka-4.randco.com.gh:9092

# Jaeger Configuration
TRACING_JAEGER_ENDPOINT=http://prod-jaeger-collector.randco.com.gh:14268/api/traces
TRACING_SAMPLE_RATE=0.01

# API Gateway
APOLLO_ROUTER_URL=https://api.randco.com.gh

# Feature Flags
ENABLE_MFA=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Log Level
LOGGING_LEVEL=warn

# CORS Settings
CORS_ALLOWED_ORIGINS=https://randco.com.gh,https://admin.randco.com.gh,https://play.randco.com.gh
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization