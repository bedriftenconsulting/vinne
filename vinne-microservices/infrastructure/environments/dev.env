# Dev Environment Configuration
ENVIRONMENT=dev

# JWT Configuration
JWT_SECRET=${DEV_JWT_SECRET}
JWT_ACCESS_TOKEN_EXPIRY=30m
JWT_REFRESH_TOKEN_EXPIRY=14d

# Database Configuration (shared instance)
DATABASE_HOST=dev-postgres.randco.internal
DATABASE_PORT=5432

# Redis Configuration
REDIS_HOST=dev-redis.randco.internal
REDIS_PORT=6379

# Kafka Configuration
KAFKA_BROKERS=dev-kafka-0.randco.internal:9092,dev-kafka-1.randco.internal:9092,dev-kafka-2.randco.internal:9092

# Jaeger Configuration
TRACING_JAEGER_ENDPOINT=http://dev-jaeger-collector.randco.internal:14268/api/traces
TRACING_SAMPLE_RATE=0.1

# API Gateway
APOLLO_ROUTER_URL=https://dev-api.randco.internal

# Feature Flags
ENABLE_MFA=false
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_NEW_TERMINAL_AUTH=true

# Rate Limiting
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=1m

# Log Level
LOGGING_LEVEL=info

# CORS Settings
CORS_ALLOWED_ORIGINS=https://dev.randco.internal,https://dev-admin.randco.internal
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization