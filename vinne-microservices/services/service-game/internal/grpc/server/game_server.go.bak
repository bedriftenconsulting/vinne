// ApproveGame approves a game
func (s *GameServer) ApproveGame(ctx context.Context, req *pb.ApproveGameRequest) (*pb.ApproveGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "ApproveGame"),
		attribute.String("game.id", req.GameId),
	)

	// Parse IDs
	gameID, err := uuid.Parse(req.GameId)
	if err != nil {
		return &pb.ApproveGameResponse{
			Success: false,
			Message: "Invalid game ID",
		}, nil
	}

	approvedBy, err := uuid.Parse(req.ApprovedBy)
	if err != nil {
		return &pb.ApproveGameResponse{
			Success: false,
			Message: "Invalid approver ID",
		}, nil
	}

	// Approve game
	if err := s.approvalService.ApproveGame(ctx, gameID, approvedBy, req.Notes); err != nil {
		return &pb.ApproveGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.ApproveGameResponse{
		Success: true,
		Message: "Game approved successfully",
	}, nil
}

// RejectGame rejects a game
func (s *GameServer) RejectGame(ctx context.Context, req *pb.RejectGameRequest) (*pb.RejectGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "RejectGame"),
		attribute.String("game.id", req.GameId),
	)

	// Parse IDs
	gameID, err := uuid.Parse(req.GameId)
	if err != nil {
		return &pb.RejectGameResponse{
			Success: false,
			Message: "Invalid game ID",
		}, nil
	}

	rejectedBy, err := uuid.Parse(req.RejectedBy)
	if err != nil {
		return &pb.RejectGameResponse{
			Success: false,
			Message: "Invalid rejector ID",
		}, nil
	}

	// Reject game
	if err := s.approvalService.RejectGame(ctx, gameID, rejectedBy, req.Reason); err != nil {
		return &pb.RejectGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.RejectGameResponse{
		Success: true,
		Message: "Game rejected successfully",
	}, nil
}

// ScheduleGame schedules a game
func (s *GameServer) ScheduleGame(ctx context.Context, req *pb.ScheduleGameRequest) (*pb.ScheduleGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "ScheduleGame"),
		attribute.String("game.id", req.GameId),
	)

	// Parse game ID
	gameID, err := uuid.Parse(req.GameId)
	if err != nil {
		return &pb.ScheduleGameResponse{
			Success: false,
			Message: "Invalid game ID",
		}, nil
	}

	// Convert timestamps
	startTime := convertProtoTimestamp(req.ScheduledStart)
	endTime := convertProtoTimestamp(req.ScheduledEnd)
	drawTime := convertProtoTimestamp(req.ScheduledDraw)

	if startTime == nil || endTime == nil || drawTime == nil {
		return &pb.ScheduleGameResponse{
			Success: false,
			Message: "Start time, end time, and draw time are required",
		}, nil
	}

	// Schedule game
	frequency := string(convertProtoFrequency(req.Frequency))
	schedule, err := s.scheduleService.ScheduleGame(ctx, gameID, *startTime, *endTime, *drawTime, frequency)
	if err != nil {
		return &pb.ScheduleGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.ScheduleGameResponse{
		Success:  true,
		Message:  "Game scheduled successfully",
		Schedule: convertGameScheduleToProto(schedule),
	}, nil
}

// GetGameSchedule gets game schedule
func (s *GameServer) GetGameSchedule(ctx context.Context, req *pb.GetGameScheduleRequest) (*pb.GetGameScheduleResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "GetGameSchedule"),
		attribute.String("game.id", req.GameId),
	)

	// Parse game ID
	gameID, err := uuid.Parse(req.GameId)
	if err != nil {
		return &pb.GetGameScheduleResponse{
			Success: false,
			Message: "Invalid game ID",
		}, nil
	}

	// Get schedules
	schedules, err := s.scheduleService.GetGameSchedule(ctx, gameID)
	if err != nil {
		return &pb.GetGameScheduleResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Convert schedules to proto
	protoSchedules := make([]*pb.GameSchedule, len(schedules))
	for i, schedule := range schedules {
		protoSchedules[i] = convertGameScheduleToProto(schedule)
	}

	return &pb.GetGameScheduleResponse{
		Success:   true,
		Message:   "Game schedules retrieved successfully",
		Schedules: protoSchedules,
	}, nil
}
