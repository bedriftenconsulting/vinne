package server

import (
	"context"
	"time"

	"github.com/google/uuid"
	pb "github.com/randco/randco-microservices/services/service-game/proto"
	"github.com/randco/service-game/internal/models"
	"github.com/randco/service-game/internal/services"
	"go.opentelemetry.io/otel/attribute"
	"go.opentelemetry.io/otel/trace"
)

// GameServer implements the gRPC GameService
type GameServer struct {
	pb.UnimplementedGameServiceServer
	gameService     services.GameService
	rulesService    services.GameRulesService
	prizeService    services.PrizeStructureService
	approvalService services.GameApprovalService
	scheduleService services.GameScheduleService
}

// NewGameServer creates a new GameServer
func NewGameServer(
	gameService services.GameService,
	rulesService services.GameRulesService,
	prizeService services.PrizeStructureService,
	approvalService services.GameApprovalService,
	scheduleService services.GameScheduleService,
) *GameServer {
	return &GameServer{
		gameService:     gameService,
		rulesService:    rulesService,
		prizeService:    prizeService,
		approvalService: approvalService,
		scheduleService: scheduleService,
	}
}

// CreateGame creates a new game
func (s *GameServer) CreateGame(ctx context.Context, req *pb.CreateGameRequest) (*pb.CreateGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "CreateGame"),
		attribute.String("game.name", req.Name),
	)

	// Convert protobuf request to service request
	serviceReq := models.CreateGameRequest{
		Code:                req.Code,
		Name:                req.Name,
		Organizer:           req.Organizer,
		GameCategory:        req.GameCategory,
		GameFormat:          req.GameFormat,
		GameType:            convertProtoStringPtr(req.GameType),
		NumberRangeMin:      req.NumberRangeMin,
		NumberRangeMax:      req.NumberRangeMax,
		SelectionCount:      req.SelectionCount,
		BonusNumberEnabled:  req.BonusNumberEnabled,
		BonusRangeMin:       convertProtoInt32Ptr(req.BonusRangeMin),
		BonusRangeMax:       convertProtoInt32Ptr(req.BonusRangeMax),
		BonusCount:          convertProtoInt32Ptr(req.BonusCount),
		StartDate:           convertProtoStringPtr(req.StartDate),
		StartTime:           convertProtoStringPtr(req.StartTime),
		EndDate:             convertProtoStringPtr(req.EndDate),
		EndTime:             convertProtoStringPtr(req.EndTime),
		DrawFrequency:       req.DrawFrequency,
		DrawDays:            req.DrawDays,
		DrawTime:            convertProtoStringPtr(req.DrawTime),
		SalesCutoffMinutes:  req.SalesCutoffMinutes,
		MinStake:            req.MinStake,
		MaxStake:            req.MaxStake,
		BasePrice:           req.BasePrice,
		MaxTicketsPerPlayer: req.MaxTicketsPerPlayer,
		MultiDrawEnabled:    req.MultiDrawEnabled,
		MaxDrawsAdvance:     convertProtoInt32Ptr(req.MaxDrawsAdvance),
		WeeklySchedule:      convertProtoBoolPtr(req.WeeklySchedule),
		Description:         convertProtoStringPtr(req.Description),
	}

	// Call service
	game, err := s.gameService.CreateGame(ctx, serviceReq)
	if err != nil {
		span.RecordError(err)
		return &pb.CreateGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Convert to protobuf response
	return &pb.CreateGameResponse{
		Game:    convertGameToProto(game),
		Success: true,
		Message: "Game created successfully",
	}, nil
}

// GetGame retrieves a game by ID
func (s *GameServer) GetGame(ctx context.Context, req *pb.GetGameRequest) (*pb.GetGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "GetGame"),
		attribute.String("game.id", req.Id),
	)

	// Parse UUID
	id, err := uuid.Parse(req.Id)
	if err != nil {
		span.RecordError(err)
		return &pb.GetGameResponse{
			Success: false,
			Message: "Invalid game ID format",
		}, nil
	}

	// Call service
	game, err := s.gameService.GetGame(ctx, id)
	if err != nil {
		span.RecordError(err)
		return &pb.GetGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Convert to protobuf response
	return &pb.GetGameResponse{
		Game:    convertGameToProto(game),
		Success: true,
		Message: "Game retrieved successfully",
	}, nil
}

// UpdateGame updates an existing game
func (s *GameServer) UpdateGame(ctx context.Context, req *pb.UpdateGameRequest) (*pb.UpdateGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "UpdateGame"),
		attribute.String("game.id", req.Id),
	)

	// Parse UUID
	id, err := uuid.Parse(req.Id)
	if err != nil {
		span.RecordError(err)
		return &pb.UpdateGameResponse{
			Success: false,
			Message: "Invalid game ID format",
		}, nil
	}

	// Convert protobuf request to service request
	// Parse draw time if provided
	var drawTime *time.Time
	if req.DrawTime != "" {
		if parsed, err := time.Parse("15:04", req.DrawTime); err == nil {
			drawTime = &parsed
		}
	}
	
	serviceReq := models.UpdateGameRequest{
		ID:             id,
		Name:           convertProtoStringPtr(req.Name),
		Description:    convertProtoStringPtr(req.Description),
		DrawTime:       drawTime,
	}

	// Call service
	game, err := s.gameService.UpdateGame(ctx, serviceReq)
	if err != nil {
		span.RecordError(err)
		return &pb.UpdateGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Convert to protobuf response
	return &pb.UpdateGameResponse{
		Game:    convertGameToProto(game),
		Success: true,
		Message: "Game updated successfully",
	}, nil
}

// ListGames lists games with filters
func (s *GameServer) ListGames(ctx context.Context, req *pb.ListGamesRequest) (*pb.ListGamesResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "ListGames"),
		attribute.Int64("pagination.page", int64(req.Page)),
		attribute.Int64("pagination.per_page", int64(req.PerPage)),
	)

	// Convert protobuf filters to service filters
	filter := models.GameFilter{
		// Type:        convertProtoGameTypeFilter(req.TypeFilter), // Skip for now since GameFilter needs updating
		Organizer:   convertProtoOrganizerFilter(req.OrganizerFilter),
		Status:      convertProtoStatusFilter(req.StatusFilter),
		SearchQuery: convertProtoStringPtr(req.SearchQuery),
	}

	// Default pagination values
	page := int(req.Page)
	perPage := int(req.PerPage)
	if page < 1 {
		page = 1
	}
	if perPage < 1 || perPage > 100 {
		perPage = 20
	}

	// Call service
	games, totalCount, err := s.gameService.ListGames(ctx, filter, page, perPage)
	if err != nil {
		span.RecordError(err)
		return &pb.ListGamesResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Convert to protobuf response
	protoGames := make([]*pb.Game, len(games))
	for i, game := range games {
		protoGames[i] = convertGameToProto(game)
	}

	return &pb.ListGamesResponse{
		Games:      protoGames,
		TotalCount: totalCount,
		Page:       int32(page),
		PerPage:    int32(perPage),
		Success:    true,
		Message:    "Games retrieved successfully",
	}, nil
}

// DeleteGame deletes a game
func (s *GameServer) DeleteGame(ctx context.Context, req *pb.DeleteGameRequest) (*pb.DeleteGameResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "DeleteGame"),
		attribute.String("game.id", req.Id),
	)

	// Parse UUID
	id, err := uuid.Parse(req.Id)
	if err != nil {
		span.RecordError(err)
		return &pb.DeleteGameResponse{
			Success: false,
			Message: "Invalid game ID format",
		}, nil
	}

	// Call service
	err = s.gameService.DeleteGame(ctx, id)
	if err != nil {
		span.RecordError(err)
		return &pb.DeleteGameResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.DeleteGameResponse{
		Success: true,
		Message: "Game deleted successfully",
	}, nil
}

// CreateGameRules creates game rules
func (s *GameServer) CreateGameRules(ctx context.Context, req *pb.CreateGameRulesRequest) (*pb.CreateGameRulesResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "CreateGameRules"),
		attribute.String("game.id", req.GameId),
	)

	// Parse game ID
	gameID, err := uuid.Parse(req.GameId)
	if err != nil {
		return &pb.CreateGameRulesResponse{
			Success: false,
			Message: "Invalid game ID",
		}, nil
	}

	// Create service request
	serviceReq := models.CreateGameRulesRequest{
		GameID:         gameID,
		NumbersToPick:  req.NumbersToPick,
		TotalNumbers:   req.TotalNumbers,
		MinSelections:  req.MinSelections,
		MaxSelections:  req.MaxSelections,
		AllowQuickPick: req.AllowQuickPick,
		SpecialRules:   convertProtoString(req.SpecialRules),
	}

	// Call service
	rules, err := s.rulesService.CreateGameRules(ctx, serviceReq)
	if err != nil {
		return &pb.CreateGameRulesResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.CreateGameRulesResponse{
		Success: true,
		Message: "Game rules created successfully",
		Rules:   convertGameRulesToProto(rules),
	}, nil
}

