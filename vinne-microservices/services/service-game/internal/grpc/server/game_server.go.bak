// UpdatePrizeStructure updates prize structure
func (s *GameServer) UpdatePrizeStructure(ctx context.Context, req *pb.UpdatePrizeStructureRequest) (*pb.UpdatePrizeStructureResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "UpdatePrizeStructure"),
		attribute.String("structure.id", req.Id),
	)

	// Get existing structure first
	structureID, _ := uuid.Parse(req.Id)
	existingStructure, err := s.prizeService.GetPrizeStructure(ctx, structureID)
	if err != nil {
		return &pb.UpdatePrizeStructureResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Update fields from request
	structure := existingStructure
	structure.TotalPrizePool = req.TotalPrizePool
	structure.HouseEdgePercentage = req.HouseEdgePercentage

	// Convert tiers
	if len(req.Tiers) > 0 {
		structure.Tiers = []models.PrizeTier{}
		for _, tier := range req.Tiers {
			structure.Tiers = append(structure.Tiers, convertProtoToPrizeTier(tier))
		}
	}

	// Update structure
	if err := s.prizeService.UpdatePrizeStructure(ctx, structure); err != nil {
		return &pb.UpdatePrizeStructureResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.UpdatePrizeStructureResponse{
		Success: true,
		Message: "Prize structure updated successfully",
	}, nil
}

