// UpdateGameRules updates game rules
func (s *GameServer) UpdateGameRules(ctx context.Context, req *pb.UpdateGameRulesRequest) (*pb.UpdateGameRulesResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "UpdateGameRules"),
		attribute.String("rules.id", req.Id),
	)

	// Get existing rules first
	rulesID, _ := uuid.Parse(req.Id)
	existingRules, err := s.rulesService.GetGameRules(ctx, rulesID)
	if err != nil {
		return &pb.UpdateGameRulesResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	// Update fields from request
	rules := existingRules
	rules.NumbersToPick = req.NumbersToPick
	rules.TotalNumbers = req.TotalNumbers
	rules.MinSelections = req.MinSelections
	rules.MaxSelections = req.MaxSelections
	rules.AllowQuickPick = req.AllowQuickPick
	if req.SpecialRules != "" {
		rules.SpecialRules = &req.SpecialRules
	}

	// Update rules
	if err := s.rulesService.UpdateGameRules(ctx, rules); err != nil {
		return &pb.UpdateGameRulesResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.UpdateGameRulesResponse{
		Success: true,
		Message: "Game rules updated successfully",
	}, nil
}

// CreatePrizeStructure creates prize structure
func (s *GameServer) CreatePrizeStructure(ctx context.Context, req *pb.CreatePrizeStructureRequest) (*pb.CreatePrizeStructureResponse, error) {
	span := trace.SpanFromContext(ctx)
	span.SetAttributes(
		attribute.String("grpc.method", "CreatePrizeStructure"),
		attribute.String("game.id", req.GameId),
	)

	// Parse game ID
	gameID, err := uuid.Parse(req.GameId)
	if err != nil {
		return &pb.CreatePrizeStructureResponse{
			Success: false,
			Message: "Invalid game ID",
		}, nil
	}

	// Convert tiers
	tiers := make([]models.PrizeTier, len(req.Tiers))
	for i, tier := range req.Tiers {
		tiers[i] = convertProtoToPrizeTier(tier)
	}

	// Create service request
	serviceReq := models.CreatePrizeStructureRequest{
		GameID:              gameID,
		TotalPrizePool:      req.TotalPrizePool,
		HouseEdgePercentage: req.HouseEdgePercentage,
		Tiers:               tiers,
	}

	// Call service
	structure, err := s.prizeService.CreatePrizeStructure(ctx, serviceReq)
	if err != nil {
		return &pb.CreatePrizeStructureResponse{
			Success: false,
			Message: err.Error(),
		}, nil
	}

	return &pb.CreatePrizeStructureResponse{
		Success:   true,
		Message:   "Prize structure created successfully",
		Structure: convertPrizeStructureToProto(structure),
	}, nil
}

