FROM golang:1.24-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git ca-certificates

ENV GOPROXY="https://proxy.golang.org,direct"
ENV GONOSUMCHECK="*"
ENV GOWORK=off
ENV GOFLAGS="-mod=mod"

COPY services/service-draw/go.mod services/service-draw/go.sum ./services/service-draw/
COPY proto ./proto
COPY shared ./shared

WORKDIR /app/services/service-draw
RUN go mod download

WORKDIR /app
COPY services/service-draw ./services/service-draw

WORKDIR /app/services/service-draw
RUN CGO_ENABLED=0 GOOS=linux go build -o main cmd/server/main.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/services/service-draw/main .
COPY --from=builder /app/services/service-draw/migrations ./migrations
EXPOSE 50060 8080
CMD ["./main"]
