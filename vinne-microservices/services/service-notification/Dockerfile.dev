FROM golang:1.24-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git ca-certificates

ENV GOPROXY="https://proxy.golang.org,direct"
ENV GONOSUMCHECK="*"
ENV GOWORK=off
ENV GOFLAGS="-mod=mod"
ENV GONOSUMDB="*"

COPY services/service-notification/go.mod services/service-notification/go.sum ./services/service-notification/
COPY proto ./proto
COPY shared ./shared

WORKDIR /app/services/service-notification
RUN go mod download || true

WORKDIR /app
COPY services/service-notification ./services/service-notification

WORKDIR /app/services/service-notification
RUN CGO_ENABLED=0 GOOS=linux go build -o main cmd/server/main.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/services/service-notification/main .
COPY --from=builder /app/services/service-notification/migrations ./migrations
EXPOSE 50063 8080
CMD ["./main"]
