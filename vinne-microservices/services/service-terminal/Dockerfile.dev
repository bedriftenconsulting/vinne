FROM golang:1.24-alpine AS builder

WORKDIR /app

RUN apk add --no-cache git ca-certificates

ENV GOFLAGS="-mod=mod"
ENV GOPROXY="https://proxy.golang.org,direct"
ENV GONOSUMCHECK="*"

COPY services/service-terminal/go.mod services/service-terminal/go.sum ./services/service-terminal/
COPY proto ./proto
COPY shared ./shared

WORKDIR /app/services/service-terminal
RUN go mod download

WORKDIR /app
COPY services/service-terminal ./services/service-terminal

WORKDIR /app/services/service-terminal
RUN CGO_ENABLED=0 GOOS=linux go build -o main cmd/server/main.go

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app
COPY --from=builder /app/services/service-terminal/main .
COPY --from=builder /app/services/service-terminal/migrations ./migrations
EXPOSE 50054 8080
CMD ["./main"]
