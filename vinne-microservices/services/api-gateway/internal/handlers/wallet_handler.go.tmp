package handlers

import (
	"context"
	"encoding/json"
	"net/http"
	"strconv"
	"strings"
	"time"

	"github.com/randco/randco-microservices/services/api-gateway/internal/grpc"
	"github.com/randco/randco-microservices/services/api-gateway/internal/router"
	"github.com/randco/randco-microservices/shared/common/logger"
	walletpb "github.com/randco/service-wallet/proto"
	"google.golang.org/protobuf/types/known/timestamppb"
)

// WalletHandler handles wallet-related requests
type WalletHandler struct {
	grpcManager *grpc.ClientManager
	logger      logger.Logger
}

// NewWalletHandler creates a new wallet handler
func NewWalletHandler(grpcManager *grpc.ClientManager, logger logger.Logger) *WalletHandler {
	return &WalletHandler{
		grpcManager: grpcManager,
		logger:      logger,
	}
}

// getWalletClient gets or creates a wallet service client
func (h *WalletHandler) getWalletClient() (walletpb.WalletServiceClient, error) {
	conn, err := h.grpcManager.GetConnection("wallet")
	if err != nil {
		return nil, err
	}
	return walletpb.NewWalletServiceClient(conn), nil
}

// CreditAgentWalletRequest represents the request to credit an agent's wallet
type CreditAgentWalletRequest struct {
	Amount        float64 `json:"amount" validate:"required,gt=0"`
	Reference     string  `json:"reference"`
	PaymentMethod string  `json:"payment_method" validate:"required"`
	Notes         string  `json:"notes"`
}

// CreditAgentWalletResponse represents the response for crediting an agent's wallet
type CreditAgentWalletResponse struct {
	Success          bool      `json:"success"`
	TransactionID    string    `json:"transaction_id"`
	CreditedAmount   float64   `json:"credited_amount"`
	CommissionAmount float64   `json:"commission_amount"`
	TotalAmount      float64   `json:"total_amount"`
	NewBalance       float64   `json:"new_balance"`
	Message          string    `json:"message"`
	Timestamp        time.Time `json:"timestamp"`
}

// CreditAgentWallet handles POST /api/v1/admin/agents/{agentId}/wallet/credit
func (h *WalletHandler) CreditAgentWallet(w http.ResponseWriter, r *http.Request) error {
	// Extract agentId from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var agentID string
	for i, part := range pathParts {
		if part == "agents" && i+1 < len(pathParts) {
			agentID = pathParts[i+1]
			break
		}
	}

	if agentID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "agent_id is required")
	}

	var req CreditAgentWalletRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid request body")
	}

	// Validate request
	if req.Amount <= 0 {
		return router.ErrorResponse(w, http.StatusBadRequest, "amount must be positive")
	}
	if req.PaymentMethod == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "payment_method is required")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	// Call gRPC service
	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	grpcReq := &walletpb.CreditAgentWalletRequest{
		AgentId:        agentID,
		Amount:         req.Amount,
		Reference:      req.Reference,
		PaymentMethod:  req.PaymentMethod,
		Notes:          req.Notes,
		IdempotencyKey: r.Header.Get("X-Idempotency-Key"),
	}

	resp, err := client.CreditAgentWallet(ctx, grpcReq)
	if err != nil {
		h.logger.Error("Failed to credit wallet", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to credit wallet")
	}

	// Convert response
	response := CreditAgentWalletResponse{
		Success:          resp.Success,
		TransactionID:    resp.TransactionId,
		CreditedAmount:   resp.CreditedAmount,
		CommissionAmount: resp.CommissionAmount,
		TotalAmount:      resp.TotalAmount,
		NewBalance:       resp.NewBalance,
		Message:          resp.Message,
		Timestamp:        resp.Timestamp.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// GetAgentWalletBalance handles GET /api/v1/admin/agents/{agentId}/wallet/balance
func (h *WalletHandler) GetAgentWalletBalance(w http.ResponseWriter, r *http.Request) error {
	// Extract agentId from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var agentID string
	for i, part := range pathParts {
		if part == "agents" && i+1 < len(pathParts) {
			agentID = pathParts[i+1]
			break
		}
	}

	if agentID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "agent_id is required")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetAgentWalletBalance(ctx, &walletpb.GetAgentWalletBalanceRequest{
		AgentId: agentID,
	})
	if err != nil {
		h.logger.Error("Failed to get balance", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get balance")
	}

	response := map[string]interface{}{
		"agent_id":          resp.AgentId,
		"balance":           resp.Balance,
		"pending_balance":   resp.PendingBalance,
		"available_balance": resp.AvailableBalance,
		"last_updated":      resp.LastUpdated.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// CreditRetailerWalletRequest represents the request to credit a retailer's wallet
type CreditRetailerWalletRequest struct {
	WalletType string  `json:"wallet_type" validate:"required,oneof=stake winning"`
	Amount     float64 `json:"amount" validate:"required,gt=0"`
	Reference  string  `json:"reference"`
	AgentID    string  `json:"agent_id"`
	Notes      string  `json:"notes"`
}

// CreditRetailerWallet handles POST /api/v1/admin/retailers/{retailerId}/wallet/credit
func (h *WalletHandler) CreditRetailerWallet(w http.ResponseWriter, r *http.Request) error {
	// Extract retailerId from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var retailerID string
	for i, part := range pathParts {
		if part == "retailers" && i+1 < len(pathParts) {
			retailerID = pathParts[i+1]
			break
		}
	}

	if retailerID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "retailer_id is required")
	}

	var req CreditRetailerWalletRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid request body")
	}

	// Map wallet type
	var walletType walletpb.WalletType
	switch req.WalletType {
	case "stake":
		walletType = walletpb.WalletType_RETAILER_STAKE
	case "winning":
		walletType = walletpb.WalletType_RETAILER_WINNING
	default:
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid wallet_type")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	grpcReq := &walletpb.CreditRetailerWalletRequest{
		RetailerId:     retailerID,
		WalletType:     walletType,
		Amount:         req.Amount,
		Reference:      req.Reference,
		AgentId:        req.AgentID,
		Notes:          req.Notes,
		IdempotencyKey: r.Header.Get("X-Idempotency-Key"),
	}

	resp, err := client.CreditRetailerWallet(ctx, grpcReq)
	if err != nil {
		h.logger.Error("Failed to credit wallet", "error", err, "retailer_id", retailerID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to credit wallet")
	}

	response := map[string]interface{}{
		"success":          resp.Success,
		"transaction_id":   resp.TransactionId,
		"credited_amount":  resp.CreditedAmount,
		"agent_commission": resp.AgentCommission,
		"new_balance":      resp.NewBalance,
		"message":          resp.Message,
		"timestamp":        resp.Timestamp.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// GetRetailerWalletBalance handles GET /api/v1/admin/retailers/{retailerId}/wallet/balance
func (h *WalletHandler) GetRetailerWalletBalance(w http.ResponseWriter, r *http.Request) error {
	// Extract retailerId from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var retailerID string
	for i, part := range pathParts {
		if part == "retailers" && i+1 < len(pathParts) {
			retailerID = pathParts[i+1]
			break
		}
	}

	if retailerID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "retailer_id is required")
	}

	walletTypeStr := r.URL.Query().Get("wallet_type")

	// Default to stake wallet if not specified
	var walletType walletpb.WalletType
	switch walletTypeStr {
	case "winning":
		walletType = walletpb.WalletType_RETAILER_WINNING
	case "stake", "":
		walletType = walletpb.WalletType_RETAILER_STAKE
		walletTypeStr = "stake" // Set default for response
	default:
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid wallet_type")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetRetailerWalletBalance(ctx, &walletpb.GetRetailerWalletBalanceRequest{
		RetailerId: retailerID,
		WalletType: walletType,
	})
	if err != nil {
		h.logger.Error("Failed to get balance", "error", err, "retailer_id", retailerID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get balance")
	}

	response := map[string]interface{}{
		"retailer_id":       resp.RetailerId,
		"wallet_type":       walletTypeStr,
		"balance":           resp.Balance,
		"pending_balance":   resp.PendingBalance,
		"available_balance": resp.AvailableBalance,
		"last_updated":      resp.LastUpdated.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// GetTransactionHistory handles GET /api/v1/admin/{entityType}/{entityId}/wallet/transactions
func (h *WalletHandler) GetTransactionHistory(w http.ResponseWriter, r *http.Request) error {
	// Extract entity type and ID from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var entityType, entityID string

	for i, part := range pathParts {
		if (part == "agents" || part == "retailers") && i+1 < len(pathParts) {
			entityType = part
			entityID = pathParts[i+1]
			break
		}
	}

	if entityID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "entity_id is required")
	}

	// Determine wallet type based on entity type
	var walletType walletpb.WalletType
	if entityType == "agents" {
		walletType = walletpb.WalletType_AGENT_STAKE
	} else {
		// For retailers, check if specific wallet type is requested
		walletTypeStr := r.URL.Query().Get("wallet_type")
		switch walletTypeStr {
		case "winning":
			walletType = walletpb.WalletType_RETAILER_WINNING
		case "stake", "":
			walletType = walletpb.WalletType_RETAILER_STAKE
		default:
			return router.ErrorResponse(w, http.StatusBadRequest, "invalid wallet_type")
		}
	}

	// Parse query parameters
	startDateStr := r.URL.Query().Get("start_date")
	endDateStr := r.URL.Query().Get("end_date")
	pageStr := r.URL.Query().Get("page")
	pageSizeStr := r.URL.Query().Get("page_size")

	// Parse dates
	var startDate, endDate *timestamppb.Timestamp
	if startDateStr != "" {
		if t, err := time.Parse(time.RFC3339, startDateStr); err == nil {
			startDate = timestamppb.New(t)
		}
	}
	if endDateStr != "" {
		if t, err := time.Parse(time.RFC3339, endDateStr); err == nil {
			endDate = timestamppb.New(t)
		}
	}

	// Parse pagination
	page := int32(1)
	pageSize := int32(20)
	if p, err := strconv.Atoi(pageStr); err == nil && p > 0 {
		page = int32(p)
	}
	if ps, err := strconv.Atoi(pageSizeStr); err == nil && ps > 0 {
		pageSize = int32(ps)
		if pageSize > 100 {
			pageSize = 100
		}
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetTransactionHistory(ctx, &walletpb.GetTransactionHistoryRequest{
		WalletOwnerId: entityID,
		WalletType:    walletType,
		StartDate:     startDate,
		EndDate:       endDate,
		Page:          page,
		PageSize:      pageSize,
	})
	if err != nil {
		h.logger.Error("Failed to get transaction history", "error", err, "entity_id", entityID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get transaction history")
	}

	// Convert transactions
	transactions := make([]map[string]interface{}, 0, len(resp.Transactions))
	for _, tx := range resp.Transactions {
		transactions = append(transactions, map[string]interface{}{
			"id":             tx.Id,
			"wallet_type":    tx.WalletType.String(),
			"type":           tx.Type.String(),
			"amount":         tx.Amount,
			"balance_before": tx.BalanceBefore,
			"balance_after":  tx.BalanceAfter,
			"reference":      tx.Reference,
			"description":    tx.Description,
			"status":         tx.Status.String(),
			"created_at":     tx.CreatedAt.AsTime(),
			"metadata":       tx.Metadata,
		})
	}

	response := map[string]interface{}{
		"transactions": transactions,
		"total_count":  resp.TotalCount,
		"page":         resp.Page,
		"page_size":    resp.PageSize,
		"has_more":     resp.HasMore,
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// SetCommissionRateRequest represents the request to set commission rate
type SetCommissionRateRequest struct {
	Rate          float64 `json:"rate" validate:"required,min=0,max=1"`
	EffectiveFrom string  `json:"effective_from"`
	Notes         string  `json:"notes"`
}

// SetCommissionRate handles POST /api/v1/admin/agents/{agentId}/commission/rate
func (h *WalletHandler) SetCommissionRate(w http.ResponseWriter, r *http.Request) error {
	// Extract agentId from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var agentID string
	for i, part := range pathParts {
		if part == "agents" && i+1 < len(pathParts) {
			agentID = pathParts[i+1]
			break
		}
	}

	if agentID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "agent_id is required")
	}

	var req SetCommissionRateRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid request body")
	}

	// Get admin user from context (set by auth middleware)
	adminUser, _ := r.Context().Value(router.ContextUserID).(string)

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.SetCommissionRate(ctx, &walletpb.SetCommissionRateRequest{
		AgentId:       agentID,
		Rate:          req.Rate,
		EffectiveFrom: req.EffectiveFrom,
		Notes:         req.Notes,
		SetBy:         adminUser,
	})
	if err != nil {
		h.logger.Error("Failed to set commission rate", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to set commission rate")
	}

	response := map[string]interface{}{
		"success":        resp.Success,
		"message":        resp.Message,
		"new_rate":       resp.NewRate,
		"effective_from": resp.EffectiveFrom.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

