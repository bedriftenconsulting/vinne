// TransferAgentToRetailerRequest represents the request for agent to retailer transfer
type TransferAgentToRetailerRequest struct {
	Amount    float64 `json:"amount" validate:"required,gt=0"`
	Reference string  `json:"reference"`
	Notes     string  `json:"notes"`
}

// TransferAgentToRetailer handles POST /api/v1/admin/agents/{agentId}/transfer/{retailerId}
func (h *WalletHandler) TransferAgentToRetailer(w http.ResponseWriter, r *http.Request) error {
	// Extract agentId and retailerId from URL path
	pathParts := strings.Split(r.URL.Path, "/")
	var agentID, retailerID string

	for i, part := range pathParts {
		if part == "agents" && i+1 < len(pathParts) {
			agentID = pathParts[i+1]
		}
		if part == "transfer" && i+1 < len(pathParts) {
			retailerID = pathParts[i+1]
			break
		}
	}

	if agentID == "" || retailerID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "agent_id and retailer_id are required")
	}

	var req TransferAgentToRetailerRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid request body")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.TransferAgentToRetailer(ctx, &walletpb.TransferAgentToRetailerRequest{
		AgentId:        agentID,
		RetailerId:     retailerID,
		Amount:         req.Amount,
		Reference:      req.Reference,
		Notes:          req.Notes,
		IdempotencyKey: r.Header.Get("X-Idempotency-Key"),
	})
	if err != nil {
		h.logger.Error("Failed to transfer", "error", err, "agent_id", agentID, "retailer_id", retailerID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to transfer")
	}

	response := map[string]interface{}{
		"success":              resp.Success,
		"transaction_id":       resp.TransactionId,
		"transferred_amount":   resp.TransferredAmount,
		"commission_charged":   resp.CommissionCharged,
		"total_deducted":       resp.TotalDeducted,
		"agent_new_balance":    resp.AgentNewBalance,
		"retailer_new_balance": resp.RetailerNewBalance,
		"message":              resp.Message,
		"timestamp":            resp.Timestamp.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// ====== AGENT PORTAL SPECIFIC ENDPOINTS ======

// GetAgentOwnWalletBalance handles GET /api/v1/agent/wallet/balance
// Gets the balance for the authenticated agent's own wallet
func (h *WalletHandler) GetAgentOwnWalletBalance(w http.ResponseWriter, r *http.Request) error {
	// Get agent ID from JWT context (set by auth middleware)
	agentID := router.GetUserID(r)
	if agentID == "" {
		return router.ErrorResponse(w, http.StatusUnauthorized, "unauthorized")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetWalletBalance(ctx, &walletpb.GetWalletBalanceRequest{
		OwnerId:    agentID,
		WalletType: walletpb.WalletType_AGENT_STAKE,
	})
	if err != nil {
		h.logger.Error("Failed to get wallet balance", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get wallet balance")
	}

	response := map[string]interface{}{
		"balance":         resp.Balance,
		"pending_balance": resp.PendingBalance,
		"wallet_type":     "agent_stake",
		"last_updated":    resp.LastUpdated.AsTime(),
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// AgentSelfTopUp handles POST /api/v1/agent/wallet/topup
// Allows an agent to top up their own wallet
func (h *WalletHandler) AgentSelfTopUp(w http.ResponseWriter, r *http.Request) error {
	agentID := router.GetUserID(r)
	if agentID == "" {
		return router.ErrorResponse(w, http.StatusUnauthorized, "unauthorized")
	}

	var req struct {
		Amount        int64  `json:"amount"`
		PaymentMethod string `json:"payment_method"`
		Reference     string `json:"reference"`
		Notes         string `json:"notes,omitempty"`
	}

	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid request body")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	grpcReq := &walletpb.CreditAgentWalletRequest{
		AgentId:        agentID,
		Amount:         req.Amount,
		PaymentMethod:  req.PaymentMethod,
		Reference:      req.Reference,
		Notes:          req.Notes,
		IdempotencyKey: r.Header.Get("X-Idempotency-Key"),
	}

	resp, err := client.CreditAgentWallet(ctx, grpcReq)
	if err != nil {
		h.logger.Error("Failed to top up wallet", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to top up wallet")
	}

	response := map[string]interface{}{
		"success":           resp.Success,
		"transaction_id":    resp.TransactionId,
		"credited_amount":   resp.CreditedAmount,
		"commission_earned": resp.CommissionEarned,
		"gross_amount":      resp.GrossAmount,
		"new_balance":       resp.NewBalance,
		"message":           resp.Message,
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// GetAgentOwnTransactions handles GET /api/v1/agent/wallet/transactions
// Gets transaction history for the authenticated agent
func (h *WalletHandler) GetAgentOwnTransactions(w http.ResponseWriter, r *http.Request) error {
	agentID := router.GetUserID(r)
	if agentID == "" {
		return router.ErrorResponse(w, http.StatusUnauthorized, "unauthorized")
	}

	// Parse query parameters
	limit, _ := strconv.ParseInt(r.URL.Query().Get("limit"), 10, 32)
	offset, _ := strconv.ParseInt(r.URL.Query().Get("offset"), 10, 32)
	startDate := r.URL.Query().Get("start_date")
	endDate := r.URL.Query().Get("end_date")

	if limit <= 0 {
		limit = 50
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetTransactionHistory(ctx, &walletpb.GetTransactionHistoryRequest{
		OwnerId:    agentID,
		WalletType: walletpb.WalletType_AGENT_STAKE,
		Limit:      int32(limit),
		Offset:     int32(offset),
		StartDate:  startDate,
		EndDate:    endDate,
	})
	if err != nil {
		h.logger.Error("Failed to get transactions", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get transactions")
	}

	var transactions []map[string]interface{}
	for _, tx := range resp.Transactions {
		transactions = append(transactions, map[string]interface{}{
			"id":             tx.Id,
			"type":           tx.Type.String(),
			"amount":         tx.Amount,
			"balance_before": tx.BalanceBefore,
			"balance_after":  tx.BalanceAfter,
			"reference":      tx.Reference,
			"description":    tx.Description,
			"commission":     tx.Commission,
			"status":         tx.Status.String(),
			"created_at":     tx.CreatedAt.AsTime(),
		})
	}

	response := map[string]interface{}{
		"transactions": transactions,
		"total":        resp.Total,
		"limit":        limit,
		"offset":       offset,
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// AgentTransferToRetailer handles POST /api/v1/agent/wallet/transfer/{retailerId}
// Allows an agent to transfer funds to their retailer
func (h *WalletHandler) AgentTransferToRetailer(w http.ResponseWriter, r *http.Request) error {
	agentID := router.GetUserID(r)
	if agentID == "" {
		return router.ErrorResponse(w, http.StatusUnauthorized, "unauthorized")
	}

	// Extract retailer ID from path
	retailerID := router.GetParam(r, "retailerId")
	if retailerID == "" {
		return router.ErrorResponse(w, http.StatusBadRequest, "retailer_id is required")
	}

	var req struct {
		Amount    int64  `json:"amount"`
		Reference string `json:"reference,omitempty"`
		Notes     string `json:"notes,omitempty"`
	}

	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return router.ErrorResponse(w, http.StatusBadRequest, "invalid request body")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	grpcReq := &walletpb.TransferAgentToRetailerRequest{
		AgentId:        agentID,
		RetailerId:     retailerID,
		Amount:         req.Amount,
		Reference:      req.Reference,
		Notes:          req.Notes,
		IdempotencyKey: r.Header.Get("X-Idempotency-Key"),
	}

	resp, err := client.TransferAgentToRetailer(ctx, grpcReq)
	if err != nil {
		h.logger.Error("Failed to transfer funds", "error", err,
			"agent_id", agentID, "retailer_id", retailerID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to transfer funds")
	}

	response := map[string]interface{}{
		"success":              resp.Success,
		"transaction_id":       resp.TransactionId,
		"transferred_amount":   resp.TransferredAmount,
		"commission_charged":   resp.CommissionCharged,
		"total_deducted":       resp.TotalDeducted,
		"agent_new_balance":    resp.AgentNewBalance,
		"retailer_new_balance": resp.RetailerNewBalance,
		"message":              resp.Message,
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// GetAgentOwnCommissionRate handles GET /api/v1/agent/commission/rate
// Gets the commission rate for the authenticated agent
func (h *WalletHandler) GetAgentOwnCommissionRate(w http.ResponseWriter, r *http.Request) error {
	agentID := router.GetUserID(r)
	if agentID == "" {
		return router.ErrorResponse(w, http.StatusUnauthorized, "unauthorized")
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetCommissionRate(ctx, &walletpb.GetCommissionRateRequest{
		AgentId: agentID,
	})
	if err != nil {
		h.logger.Error("Failed to get commission rate", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get commission rate")
	}

	response := map[string]interface{}{
		"rate":           resp.Rate,
		"effective_from": resp.EffectiveFrom.AsTime(),
		"set_by":         resp.SetBy,
		"notes":          resp.Notes,
	}

	return router.WriteJSON(w, http.StatusOK, response)
}

// GetAgentCommissionHistory handles GET /api/v1/agent/commission/history
// Gets commission history for the authenticated agent
func (h *WalletHandler) GetAgentCommissionHistory(w http.ResponseWriter, r *http.Request) error {
	agentID := router.GetUserID(r)
	if agentID == "" {
		return router.ErrorResponse(w, http.StatusUnauthorized, "unauthorized")
	}

	// Parse query parameters
	limit, _ := strconv.ParseInt(r.URL.Query().Get("limit"), 10, 32)
	offset, _ := strconv.ParseInt(r.URL.Query().Get("offset"), 10, 32)
	startDate := r.URL.Query().Get("start_date")
	endDate := r.URL.Query().Get("end_date")

	if limit <= 0 {
		limit = 50
	}

	// Get wallet client
	client, err := h.getWalletClient()
	if err != nil {
		h.logger.Error("Failed to get wallet client", "error", err)
		return router.ErrorResponse(w, http.StatusInternalServerError, "service unavailable")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetCommissionHistory(ctx, &walletpb.GetCommissionHistoryRequest{
		AgentId:   agentID,
		Limit:     int32(limit),
		Offset:    int32(offset),
		StartDate: startDate,
		EndDate:   endDate,
	})
	if err != nil {
		h.logger.Error("Failed to get commission history", "error", err, "agent_id", agentID)
		return router.ErrorResponse(w, http.StatusInternalServerError, "failed to get commission history")
	}

	var commissions []map[string]interface{}
	for _, comm := range resp.Commissions {
		commissions = append(commissions, map[string]interface{}{
			"id":                comm.Id,
			"transaction_id":    comm.TransactionId,
			"amount":            comm.Amount,
			"rate":              comm.Rate,
			"commission_amount": comm.CommissionAmount,
			"type":              comm.Type,
			"description":       comm.Description,
			"created_at":        comm.CreatedAt.AsTime(),
		})
	}

	response := map[string]interface{}{
		"commissions": commissions,
		"total":       resp.Total,
		"limit":       limit,
		"offset":      offset,
	}

	return router.WriteJSON(w, http.StatusOK, response)
}
