// ApproveGame approves a game for operation
func (h *gameHandlerImpl) ApproveGame(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	var req struct {
		ApprovedBy string `json:"approved_by"`
		Comments   string `json:"comments"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context (set by auth middleware)
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.ApprovedBy
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.ApproveGame(ctx, &gamepb.ApproveGameRequest{
		GameId:     gameID,
		ApprovedBy: userID,
		Comments:   req.Comments,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to approve game")
	}

	return response.Success(w, http.StatusOK, "Game approved successfully", h.convertGame(resp.Game))
}

// RejectGame rejects a game
func (h *gameHandlerImpl) RejectGame(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	var req struct {
		RejectedBy string `json:"rejected_by"`
		Reason     string `json:"reason"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.RejectedBy
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.RejectGame(ctx, &gamepb.RejectGameRequest{
		GameId:     gameID,
		RejectedBy: userID,
		Reason:     req.Reason,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to reject game")
	}

	return response.Success(w, http.StatusOK, "Game rejected", h.convertGame(resp.Game))
}

// GetPrizeStructure retrieves game prize structure
func (h *gameHandlerImpl) GetPrizeStructure(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetPrizeStructure(ctx, &gamepb.GetPrizeStructureRequest{
		GameId: gameID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to get prize structure")
	}

	tiers := make([]map[string]interface{}, 0, len(resp.Tiers))
	for _, tier := range resp.Tiers {
		tiers = append(tiers, map[string]interface{}{
			"tier":             tier.Tier,
			"matching_numbers": tier.MatchingNumbers,
			"prize_amount":     float64(tier.PrizeAmount) / 100, // Convert from pesewas to GHS
			"prize_percentage": tier.PrizePercentage,
			"odds":             tier.Odds,
			"is_jackpot":       tier.IsJackpot,
			"pari_mutuel":      tier.PariMutuel,
		})
	}

	return response.Success(w, http.StatusOK, "Prize structure retrieved successfully", map[string]interface{}{
		"game_id":          gameID,
		"tiers":            tiers,
		"total_prize_pool": float64(resp.TotalPrizePool) / 100,
	})
}

// UpdatePrizeStructure updates game prize structure
func (h *gameHandlerImpl) UpdatePrizeStructure(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	var req struct {
		Tiers []struct {
			Tier            int32   `json:"tier"`
			MatchingNumbers int32   `json:"matching_numbers"`
			PrizeAmount     float64 `json:"prize_amount"`
			PrizePercentage float32 `json:"prize_percentage"`
			Odds            string  `json:"odds"`
			IsJackpot       bool    `json:"is_jackpot"`
			PariMutuel      bool    `json:"pari_mutuel"`
		} `json:"tiers"`
		TotalPrizePool float64 `json:"total_prize_pool"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	// Convert tiers
	tiers := make([]*gamepb.PrizeTier, 0, len(req.Tiers))
	for _, t := range req.Tiers {
		tiers = append(tiers, &gamepb.PrizeTier{
			Tier:            t.Tier,
			MatchingNumbers: t.MatchingNumbers,
			PrizeAmount:     int64(t.PrizeAmount * 100), // Convert to pesewas
			PrizePercentage: t.PrizePercentage,
			Odds:            t.Odds,
			IsJackpot:       t.IsJackpot,
			PariMutuel:      t.PariMutuel,
		})
	}

	_, err = client.UpdatePrizeStructure(ctx, &gamepb.UpdatePrizeStructureRequest{
		GameId:         gameID,
		Tiers:          tiers,
		TotalPrizePool: int64(req.TotalPrizePool * 100),
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to update prize structure")
	}

	return response.Success(w, http.StatusOK, "Prize structure updated successfully", nil)
}

