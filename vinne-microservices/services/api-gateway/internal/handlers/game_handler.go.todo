// CloneGame clones an existing game
func (h *gameHandlerImpl) CloneGame(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	var req struct {
		NewName      string `json:"new_name"`
		NewOrganizer string `json:"new_organizer"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.CloneGame(ctx, &gamepb.CloneGameRequest{
		GameId:       gameID,
		NewName:      req.NewName,
		NewOrganizer: req.NewOrganizer,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to clone game")
	}

	return response.Success(w, http.StatusCreated, "Game cloned successfully", h.convertGame(resp.Game))
}

