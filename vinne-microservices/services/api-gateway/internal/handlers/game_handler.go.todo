package handlers

import (
	"context"
	"net/http"
	"strconv"
	"time"

	"github.com/randco/randco-microservices/services/api-gateway/internal/grpc"
	"github.com/randco/randco-microservices/services/api-gateway/internal/response"
	"github.com/randco/randco-microservices/services/api-gateway/internal/router"
	gamepb "github.com/randco/randco-microservices/services/service-game/proto"
	"github.com/randco/randco-microservices/shared/common/logger"
	"google.golang.org/grpc/codes"
	"google.golang.org/grpc/status"
)

// GameHandler defines game management operations
type GameHandler interface {
	CreateGame(w http.ResponseWriter, r *http.Request) error
	GetGame(w http.ResponseWriter, r *http.Request) error
	ListGames(w http.ResponseWriter, r *http.Request) error
	UpdateGame(w http.ResponseWriter, r *http.Request) error
	DeleteGame(w http.ResponseWriter, r *http.Request) error
	ApproveGame(w http.ResponseWriter, r *http.Request) error
	RejectGame(w http.ResponseWriter, r *http.Request) error
	GetPrizeStructure(w http.ResponseWriter, r *http.Request) error
	UpdatePrizeStructure(w http.ResponseWriter, r *http.Request) error
	ScheduleGame(w http.ResponseWriter, r *http.Request) error
	GetGameSchedule(w http.ResponseWriter, r *http.Request) error
	UpdateGameStatus(w http.ResponseWriter, r *http.Request) error
	GetGameStatistics(w http.ResponseWriter, r *http.Request) error
	CloneGame(w http.ResponseWriter, r *http.Request) error
	GetGameRules(w http.ResponseWriter, r *http.Request) error
	UpdateGameRules(w http.ResponseWriter, r *http.Request) error
}

type gameHandlerImpl struct {
	grpcManager *grpc.ClientManager
	log         logger.Logger
}

// NewGameHandler creates a new game handler
func NewGameHandler(grpcManager *grpc.ClientManager, log logger.Logger) GameHandler {
	return &gameHandlerImpl{
		grpcManager: grpcManager,
		log:         log,
	}
}

// CreateGame handles game creation
func (h *gameHandlerImpl) CreateGame(w http.ResponseWriter, r *http.Request) error {
	var req struct {
		Name        string  `json:"name"`
		Type        string  `json:"type"`
		Description string  `json:"description"`
		Organizer   string  `json:"organizer"`
		MinPrice    float64 `json:"min_price"`
		MaxPrice    float64 `json:"max_price"`
		DrawType    string  `json:"draw_type"`
		MaxNumbers  int32   `json:"max_numbers"`
		NumberRange struct {
			Min int32 `json:"min"`
			Max int32 `json:"max"`
		} `json:"number_range"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Validate required fields
	if req.Name == "" || req.Type == "" || req.Organizer == "" {
		return response.ValidationError(w, "Missing required fields", map[string]string{
			"required": "name, type, organizer",
		})
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	// Convert prices to pesewas (smallest unit)
	minPricePesewas := int64(req.MinPrice * 100)
	maxPricePesewas := int64(req.MaxPrice * 100)

	grpcReq := &gamepb.CreateGameRequest{
		Name:        req.Name,
		Type:        req.Type,
		Description: req.Description,
		Organizer:   req.Organizer,
		MinPrice:    minPricePesewas,
		MaxPrice:    maxPricePesewas,
		DrawType:    req.DrawType,
		MaxNumbers:  req.MaxNumbers,
		MinNumber:   req.NumberRange.Min,
		MaxNumber:   req.NumberRange.Max,
	}

	resp, err := client.CreateGame(ctx, grpcReq)
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to create game")
	}

	return response.Success(w, http.StatusCreated, "Game created successfully", h.convertGame(resp.Game))
}

// GetGame retrieves a game by ID
func (h *gameHandlerImpl) GetGame(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetGame(ctx, &gamepb.GetGameRequest{
		GameId: gameID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to get game")
	}

	return response.Success(w, http.StatusOK, "Game retrieved successfully", h.convertGame(resp.Game))
}

// ListGames retrieves all games with pagination
func (h *gameHandlerImpl) ListGames(w http.ResponseWriter, r *http.Request) error {
	page, _ := strconv.Atoi(r.URL.Query().Get("page"))
	if page < 1 {
		page = 1
	}
	perPage, _ := strconv.Atoi(r.URL.Query().Get("per_page"))
	if perPage < 1 || perPage > 100 {
		perPage = 20
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.ListGames(ctx, &gamepb.ListGamesRequest{
		Page:      int32(page),
		PageSize:  int32(perPage),
		Organizer: r.URL.Query().Get("organizer"),
		Type:      r.URL.Query().Get("type"),
		Status:    r.URL.Query().Get("status"),
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to list games")
	}

	games := make([]interface{}, 0, len(resp.Games))
	for _, g := range resp.Games {
		games = append(games, h.convertGame(g))
	}

	return response.SuccessWithPagination(w, "Games retrieved successfully", games, page, perPage, int(resp.Total))
}

// UpdateGame updates game information
func (h *gameHandlerImpl) UpdateGame(w http.ResponseWriter, r *http.Request) error {
	gameID := router.GetParam(r, "id")
	if gameID == "" {
		return response.ValidationError(w, "Game ID is required", nil)
	}

	var req struct {
		Name        string  `json:"name"`
		Description string  `json:"description"`
		MinPrice    float64 `json:"min_price"`
		MaxPrice    float64 `json:"max_price"`
		MaxNumbers  int32   `json:"max_numbers"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	client, err := h.getGameClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Game")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	// Convert prices to pesewas
	minPricePesewas := int64(req.MinPrice * 100)
	maxPricePesewas := int64(req.MaxPrice * 100)

	grpcReq := &gamepb.UpdateGameRequest{
		GameId:      gameID,
		Name:        &req.Name,
		Description: &req.Description,
		MinPrice:    &minPricePesewas,
		MaxPrice:    &maxPricePesewas,
		MaxNumbers:  &req.MaxNumbers,
	}

	resp, err := client.UpdateGame(ctx, grpcReq)
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to update game")
	}

	return response.Success(w, http.StatusOK, "Game updated successfully", h.convertGame(resp.Game))
}

