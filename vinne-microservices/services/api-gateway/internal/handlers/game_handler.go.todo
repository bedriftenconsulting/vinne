// Helper methods

func (h *gameHandlerImpl) getGameClient() (gamepb.GameServiceClient, error) {
	conn, err := h.grpcManager.GetConnection("game")
	if err != nil {
		h.log.Error("Failed to get game service connection", "error", err)
		return nil, err
	}
	return gamepb.NewGameServiceClient(conn), nil
}

func (h *gameHandlerImpl) convertGame(g *gamepb.Game) map[string]interface{} {
	if g == nil {
		return nil
	}

	return map[string]interface{}{
		"id":          g.Id,
		"name":        g.Name,
		"type":        g.Type,
		"description": g.Description,
		"organizer":   g.Organizer,
		"min_price":   float64(g.MinPrice) / 100, // Convert from pesewas to GHS
		"max_price":   float64(g.MaxPrice) / 100, // Convert from pesewas to GHS
		"status":      g.Status,
		"draw_type":   g.DrawType,
		"max_numbers": g.MaxNumbers,
		"number_range": map[string]int32{
			"min": g.MinNumber,
			"max": g.MaxNumber,
		},
		"created_at":  g.CreatedAt,
		"updated_at":  g.UpdatedAt,
		"approved_at": g.ApprovedAt,
		"approved_by": g.ApprovedBy,
	}
}

func (h *gameHandlerImpl) handleGRPCError(w http.ResponseWriter, err error, defaultMsg string) error {
	st, ok := status.FromError(err)
	if !ok {
		h.log.Error(defaultMsg, "error", err)
		return response.InternalError(w, defaultMsg)
	}

	switch st.Code() {
	case codes.NotFound:
		return response.NotFoundError(w, "Game")
	case codes.InvalidArgument:
		return response.ValidationError(w, st.Message(), nil)
	case codes.AlreadyExists:
		return response.ConflictError(w, st.Message())
	case codes.PermissionDenied:
		return response.ForbiddenError(w, st.Message())
	case codes.Unauthenticated:
		return response.UnauthorizedError(w, st.Message())
	case codes.Unavailable:
		return response.ServiceUnavailableError(w, "Game")
	default:
		h.log.Error(defaultMsg, "error", err, "code", st.Code())
		return response.InternalError(w, defaultMsg)
	}
}
