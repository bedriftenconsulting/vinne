// PrepareDraw prepares a draw for execution (Stage 1)
func (h *drawHandlerImpl) PrepareDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 30*time.Second)
	defer cancel()

	resp, err := client.PrepareDraw(ctx, &drawpb.PrepareDrawRequest{
		DrawId: drawID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to prepare draw")
	}

	return response.Success(w, http.StatusOK, "Draw prepared successfully", map[string]interface{}{
		"draw_id":       drawID,
		"stage":         resp.Stage,
		"status":        resp.Status,
		"total_entries": resp.TotalEntries,
		"valid_entries": resp.ValidEntries,
		"locked_at":     resp.LockedAt,
		"can_proceed":   resp.CanProceed,
	})
}

// ExecuteDraw executes the draw (Stage 2)
func (h *drawHandlerImpl) ExecuteDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		DrawMethod string  `json:"draw_method"` // "RNG" or "PHYSICAL"
		Numbers    []int32 `json:"numbers"`     // For physical draw
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 30*time.Second)
	defer cancel()

	resp, err := client.ExecuteDraw(ctx, &drawpb.ExecuteDrawRequest{
		DrawId:     drawID,
		DrawMethod: req.DrawMethod,
		Numbers:    req.Numbers,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to execute draw")
	}

	return response.Success(w, http.StatusOK, "Draw executed successfully", map[string]interface{}{
		"draw_id":         drawID,
		"stage":           resp.Stage,
		"status":          resp.Status,
		"winning_numbers": resp.WinningNumbers,
		"draw_method":     resp.DrawMethod,
		"executed_at":     resp.ExecutedAt,
	})
}

// SaveDrawProgress saves draw progress for resumption
func (h *drawHandlerImpl) SaveDrawProgress(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		Stage    string                 `json:"stage"`
		Progress map[string]interface{} `json:"progress"`
		Notes    string                 `json:"notes"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	// Convert progress map to string (in real implementation, use proper serialization)
	progressStr := ""
	for k, v := range req.Progress {
		progressStr += k + "=" + v.(string) + ";"
	}

	_, err = client.SaveDrawProgress(ctx, &drawpb.SaveDrawProgressRequest{
		DrawId:   drawID,
		Stage:    req.Stage,
		Progress: progressStr,
		Notes:    req.Notes,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to save draw progress")
	}

	return response.Success(w, http.StatusOK, "Draw progress saved successfully", nil)
}

// RestartDraw restarts a draw (requires special permission)
func (h *drawHandlerImpl) RestartDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		Reason      string `json:"reason"`
		RestartedBy string `json:"restarted_by"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.RestartedBy
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.RestartDraw(ctx, &drawpb.RestartDrawRequest{
		DrawId:      drawID,
		Reason:      req.Reason,
		RestartedBy: userID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to restart draw")
	}

	return response.Success(w, http.StatusOK, "Draw restarted successfully", h.convertDraw(resp.Draw))
}

// CommitDrawResults commits draw results (Stage 3)
func (h *drawHandlerImpl) CommitDrawResults(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		WinningNumbers []int32 `json:"winning_numbers"`
		CommittedBy    string  `json:"committed_by"`
		NLAReference   string  `json:"nla_reference"`
		NLASignature   string  `json:"nla_signature"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.CommittedBy
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 30*time.Second)
	defer cancel()

	resp, err := client.CommitDrawResults(ctx, &drawpb.CommitDrawResultsRequest{
		DrawId:         drawID,
		WinningNumbers: req.WinningNumbers,
		CommittedBy:    userID,
		NlaReference:   req.NLAReference,
		NlaSignature:   req.NLASignature,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to commit draw results")
	}

	return response.Success(w, http.StatusOK, "Draw results committed successfully", map[string]interface{}{
		"draw_id":        drawID,
		"stage":          resp.Stage,
		"status":         resp.Status,
		"total_winners":  resp.TotalWinners,
		"total_payout":   float64(resp.TotalPayout) / 100,
		"big_wins_count": resp.BigWinsCount,
		"committed_at":   resp.CommittedAt,
	})
}

// ProcessPayout processes draw payouts (Stage 4)
func (h *drawHandlerImpl) ProcessPayout(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		ExcludeBigWins bool   `json:"exclude_big_wins"`
		ProcessedBy    string `json:"processed_by"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.ProcessedBy
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 60*time.Second) // Longer timeout for payout processing
	defer cancel()

	resp, err := client.ProcessPayout(ctx, &drawpb.ProcessPayoutRequest{
		DrawId:         drawID,
		ExcludeBigWins: req.ExcludeBigWins,
		ProcessedBy:    userID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to process payout")
	}

	return response.Success(w, http.StatusOK, "Payout processed successfully", map[string]interface{}{
		"draw_id":           drawID,
		"processed_count":   resp.ProcessedCount,
		"failed_count":      resp.FailedCount,
		"total_amount":      float64(resp.TotalAmount) / 100,
		"big_wins_excluded": resp.BigWinsExcluded,
		"big_wins_amount":   float64(resp.BigWinsAmount) / 100,
		"status":            resp.Status,
		"processed_at":      resp.ProcessedAt,
	})
}

// GetDrawResults retrieves draw results
func (h *drawHandlerImpl) GetDrawResults(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetDrawResults(ctx, &drawpb.GetDrawResultsRequest{
		DrawId: drawID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to get draw results")
	}

	// Convert prize distributions
	distributions := make([]map[string]interface{}, 0, len(resp.PrizeDistributions))
	for _, pd := range resp.PrizeDistributions {
		distributions = append(distributions, map[string]interface{}{
			"tier":          pd.Tier,
			"winners_count": pd.WinnersCount,
			"prize_amount":  float64(pd.PrizeAmount) / 100,
			"total_payout":  float64(pd.TotalPayout) / 100,
		})
	}

	return response.Success(w, http.StatusOK, "Draw results retrieved successfully", map[string]interface{}{
		"draw_id":             drawID,
		"winning_numbers":     resp.WinningNumbers,
		"total_winners":       resp.TotalWinners,
		"total_payout":        float64(resp.TotalPayout) / 100,
		"prize_distributions": distributions,
		"draw_date":           resp.DrawDate,
		"nla_reference":       resp.NlaReference,
		"validated":           resp.Validated,
	})
}

// ValidateDraw validates draw results with NLA
func (h *drawHandlerImpl) ValidateDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		NLAReference   string `json:"nla_reference"`
		NLASignature   string `json:"nla_signature"`
		ValidatedBy    string `json:"validated_by"`
		ValidationNote string `json:"validation_note"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.ValidatedBy
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.ValidateDraw(ctx, &drawpb.ValidateDrawRequest{
		DrawId:         drawID,
		NlaReference:   req.NLAReference,
		NlaSignature:   req.NLASignature,
		ValidatedBy:    userID,
		ValidationNote: req.ValidationNote,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to validate draw")
	}

	return response.Success(w, http.StatusOK, "Draw validated successfully", map[string]interface{}{
		"draw_id":      drawID,
		"validated":    resp.Validated,
		"validated_at": resp.ValidatedAt,
		"validated_by": resp.ValidatedBy,
	})
}

