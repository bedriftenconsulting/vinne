// RecordPhysicalDraw records results from a physical draw conducted at NLA premises
func (h *drawHandlerImpl) RecordPhysicalDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		WinningNumbers []int32  `json:"winning_numbers"`
		BonusNumbers   []int32  `json:"bonus_numbers"`
		NLAOfficials   []string `json:"nla_officials"`
		WitnessNames   []string `json:"witness_names"`
		VideoReference string   `json:"video_reference"`
		RecordedBy     string   `json:"recorded_by"`
		DrawLocation   string   `json:"draw_location"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	// Get user ID from context
	userID := router.GetUserID(r)
	if userID == "" {
		userID = req.RecordedBy
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.RecordPhysicalDraw(ctx, &drawpb.RecordPhysicalDrawRequest{
		DrawId:         drawID,
		WinningNumbers: req.WinningNumbers,
		BonusNumbers:   req.BonusNumbers,
		NlaOfficials:   req.NLAOfficials,
		WitnessNames:   req.WitnessNames,
		VideoReference: req.VideoReference,
		RecordedBy:     userID,
		DrawLocation:   req.DrawLocation,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to record physical draw")
	}

	return response.Success(w, http.StatusOK, "Physical draw recorded successfully", map[string]interface{}{
		"draw_id":       drawID,
		"recorded":      resp.Recorded,
		"recorded_at":   resp.RecordedAt,
		"nla_reference": resp.NlaReference,
	})
}

// Helper methods

func (h *drawHandlerImpl) getDrawClient() (drawpb.DrawServiceClient, error) {
	conn, err := h.grpcManager.GetConnection("draw")
	if err != nil {
		h.log.Error("Failed to get draw service connection", "error", err)
		return nil, err
	}
	return drawpb.NewDrawServiceClient(conn), nil
}

func (h *drawHandlerImpl) convertDraw(d *drawpb.Draw) map[string]interface{} {
	if d == nil {
		return nil
	}

	return map[string]interface{}{
		"id":              d.Id,
		"game_id":         d.GameId,
		"start_date":      d.StartDate,
		"end_date":        d.EndDate,
		"draw_time":       d.DrawTime,
		"status":          d.Status,
		"stage":           d.Stage,
		"winning_numbers": d.WinningNumbers,
		"total_tickets":   d.TotalTickets,
		"total_sales":     float64(d.TotalSales) / 100,
		"total_prizes":    float64(d.TotalPrizes) / 100,
		"description":     d.Description,
		"created_at":      d.CreatedAt,
		"updated_at":      d.UpdatedAt,
		"executed_at":     d.ExecutedAt,
		"validated":       d.Validated,
		"nla_reference":   d.NlaReference,
	}
}

func (h *drawHandlerImpl) handleGRPCError(w http.ResponseWriter, err error, defaultMsg string) error {
	st, ok := status.FromError(err)
	if !ok {
		h.log.Error(defaultMsg, "error", err)
		return response.InternalError(w, defaultMsg)
	}

	switch st.Code() {
	case codes.NotFound:
		return response.NotFoundError(w, "Draw")
	case codes.InvalidArgument:
		return response.ValidationError(w, st.Message(), nil)
	case codes.AlreadyExists:
		return response.ConflictError(w, st.Message())
	case codes.PermissionDenied:
		return response.ForbiddenError(w, st.Message())
	case codes.Unauthenticated:
		return response.UnauthorizedError(w, st.Message())
	case codes.FailedPrecondition:
		return response.ValidationError(w, st.Message(), map[string]string{
			"error": "precondition_failed",
		})
	case codes.Unavailable:
		return response.ServiceUnavailableError(w, "Draw")
	default:
		h.log.Error(defaultMsg, "error", err, "code", st.Code())
		return response.InternalError(w, defaultMsg)
	}
}
