package handlers

import (
	"context"
	"net/http"
	"strconv"
	"time"

	"github.com/randco/randco-microservices/services/api-gateway/internal/grpc"
	"github.com/randco/randco-microservices/services/api-gateway/internal/response"
	"github.com/randco/randco-microservices/services/api-gateway/internal/router"
	drawpb "github.com/randco/randco-microservices/services/service-draw/proto"
	"github.com/randco/randco-microservices/shared/common/logger"
	"google.golang.org/grpc/codes"
	"google.golang.org/grpc/status"
	"google.golang.org/protobuf/types/known/timestamppb"
)

// DrawHandler defines draw management operations
type DrawHandler interface {
	CreateDraw(w http.ResponseWriter, r *http.Request) error
	GetDraw(w http.ResponseWriter, r *http.Request) error
	ListDraws(w http.ResponseWriter, r *http.Request) error
	UpdateDraw(w http.ResponseWriter, r *http.Request) error
	DeleteDraw(w http.ResponseWriter, r *http.Request) error
	PrepareDraw(w http.ResponseWriter, r *http.Request) error
	ExecuteDraw(w http.ResponseWriter, r *http.Request) error
	SaveDrawProgress(w http.ResponseWriter, r *http.Request) error
	RestartDraw(w http.ResponseWriter, r *http.Request) error
	CommitDrawResults(w http.ResponseWriter, r *http.Request) error
	ProcessPayout(w http.ResponseWriter, r *http.Request) error
	GetDrawResults(w http.ResponseWriter, r *http.Request) error
	ValidateDraw(w http.ResponseWriter, r *http.Request) error
	GetDrawStatistics(w http.ResponseWriter, r *http.Request) error
	GetWinningNumbers(w http.ResponseWriter, r *http.Request) error
	RecordPhysicalDraw(w http.ResponseWriter, r *http.Request) error
}

type drawHandlerImpl struct {
	grpcManager *grpc.ClientManager
	log         logger.Logger
}

// NewDrawHandler creates a new draw handler
func NewDrawHandler(grpcManager *grpc.ClientManager, log logger.Logger) DrawHandler {
	return &drawHandlerImpl{
		grpcManager: grpcManager,
		log:         log,
	}
}

// CreateDraw creates a new draw
func (h *drawHandlerImpl) CreateDraw(w http.ResponseWriter, r *http.Request) error {
	var req struct {
		GameID        string `json:"game_id"`
		DrawName      string `json:"draw_name"`
		ScheduledTime string `json:"scheduled_time"`
		DrawLocation  string `json:"draw_location"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	if req.GameID == "" || req.DrawName == "" {
		return response.ValidationError(w, "Missing required fields", map[string]string{
			"required": "game_id, draw_name",
		})
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	// Parse scheduled time if provided
	var scheduledTime *timestamppb.Timestamp
	if req.ScheduledTime != "" {
		parsedTime, err := time.Parse(time.RFC3339, req.ScheduledTime)
		if err != nil {
			return response.ValidationError(w, "Invalid scheduled_time format", map[string]string{
				"error": "scheduled_time must be in RFC3339 format",
			})
		}
		scheduledTime = timestamppb.New(parsedTime)
	}

	grpcReq := &drawpb.CreateDrawRequest{
		GameId:        req.GameID,
		DrawName:      req.DrawName,
		ScheduledTime: scheduledTime,
		DrawLocation:  req.DrawLocation,
	}

	resp, err := client.CreateDraw(ctx, grpcReq)
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to create draw")
	}

	return response.Success(w, http.StatusCreated, "Draw created successfully", h.convertDraw(resp.Draw))
}

// GetDraw retrieves a draw by ID
func (h *drawHandlerImpl) GetDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.GetDraw(ctx, &drawpb.GetDrawRequest{
		DrawId: drawID,
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to get draw")
	}

	return response.Success(w, http.StatusOK, "Draw retrieved successfully", h.convertDraw(resp.Draw))
}

// ListDraws retrieves all draws with pagination
func (h *drawHandlerImpl) ListDraws(w http.ResponseWriter, r *http.Request) error {
	page, _ := strconv.Atoi(r.URL.Query().Get("page"))
	if page < 1 {
		page = 1
	}
	perPage, _ := strconv.Atoi(r.URL.Query().Get("per_page"))
	if perPage < 1 || perPage > 100 {
		perPage = 20
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	resp, err := client.ListDraws(ctx, &drawpb.ListDrawsRequest{
		Page:     int32(page),
		PageSize: int32(perPage),
		GameId:   r.URL.Query().Get("game_id"),
		Status:   r.URL.Query().Get("status"),
	})
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to list draws")
	}

	draws := make([]interface{}, 0, len(resp.Draws))
	for _, d := range resp.Draws {
		draws = append(draws, h.convertDraw(d))
	}

	return response.SuccessWithPagination(w, "Draws retrieved successfully", draws, page, perPage, int(resp.Total))
}

// UpdateDraw updates draw information
func (h *drawHandlerImpl) UpdateDraw(w http.ResponseWriter, r *http.Request) error {
	drawID := router.GetParam(r, "id")
	if drawID == "" {
		return response.ValidationError(w, "Draw ID is required", nil)
	}

	var req struct {
		StartDate   string `json:"start_date"`
		EndDate     string `json:"end_date"`
		DrawTime    string `json:"draw_time"`
		Description string `json:"description"`
	}

	if err := router.ReadJSON(r, &req); err != nil {
		return response.ValidationError(w, "Invalid request body", map[string]string{
			"error": err.Error(),
		})
	}

	client, err := h.getDrawClient()
	if err != nil {
		return response.ServiceUnavailableError(w, "Draw")
	}

	ctx, cancel := context.WithTimeout(r.Context(), 10*time.Second)
	defer cancel()

	grpcReq := &drawpb.UpdateDrawRequest{
		DrawId:      drawID,
		StartDate:   &req.StartDate,
		EndDate:     &req.EndDate,
		DrawTime:    &req.DrawTime,
		Description: &req.Description,
	}

	resp, err := client.UpdateDraw(ctx, grpcReq)
	if err != nil {
		return h.handleGRPCError(w, err, "Failed to update draw")
	}

	return response.Success(w, http.StatusOK, "Draw updated successfully", h.convertDraw(resp.Draw))
}

