#!/bin/bash

# Commit message hook for Rand Lottery Microservices
# Enforces commit message standards

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Read the commit message
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

echo "📝 Checking commit message format..."

# Check if the commit message is empty
if [ -z "$COMMIT_MSG" ]; then
    echo -e "${RED}✗ Commit message cannot be empty${NC}"
    exit 1
fi

# Get the first line of the commit message
FIRST_LINE=$(echo "$COMMIT_MSG" | head -n1)

# Check minimum length (at least 10 characters)
if [ ${#FIRST_LINE} -lt 10 ]; then
    echo -e "${RED}✗ Commit message too short (minimum 10 characters)${NC}"
    exit 1
fi

# Check maximum length of first line (72 characters)
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo -e "${YELLOW}⚠ First line of commit message exceeds 72 characters${NC}"
    echo "  Consider making it more concise"
fi

# Check for conventional commit format (optional but recommended)
CONVENTIONAL_PATTERN="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .+"
if [[ "$FIRST_LINE" =~ $CONVENTIONAL_PATTERN ]]; then
    echo -e "${GREEN}✓ Commit message follows conventional format${NC}"
else
    echo -e "${YELLOW}ℹ Commit message format:${NC}"
    echo "  Consider using conventional commits format:"
    echo "  feat: add new feature"
    echo "  fix: fix a bug"
    echo "  docs: documentation changes"
    echo "  style: code style changes"
    echo "  refactor: code refactoring"
    echo "  test: add or update tests"
    echo "  chore: maintenance tasks"
    echo "  perf: performance improvements"
    echo "  ci: CI/CD changes"
    echo "  build: build system changes"
fi

# Check for issue/ticket reference (optional)
if echo "$COMMIT_MSG" | grep -qE "(#[0-9]+|RAND-[0-9]+|closes|fixes|resolves)"; then
    echo -e "${GREEN}✓ Commit message contains issue reference${NC}"
fi

# Check that commit doesn't contain Claude Code signature
if echo "$COMMIT_MSG" | grep -qiE "(claude code|co-authored-by:.*claude|generated with.*claude)"; then
    echo -e "${RED}✗ Commit message contains Claude Code signature${NC}"
    echo "  Per CLAUDE.md: Don't include Claude Code as co-author or use Claude Code signature"
    
    # Remove Claude Code signatures
    sed -i '' '/[Cc]laude [Cc]ode/d' "$COMMIT_MSG_FILE"
    sed -i '' '/Co-[Aa]uthored-[Bb]y:.*[Cc]laude/d' "$COMMIT_MSG_FILE"
    sed -i '' '/Generated with.*[Cc]laude/d' "$COMMIT_MSG_FILE"
    
    echo -e "${YELLOW}ℹ Claude Code signatures have been removed from commit message${NC}"
fi

# Check for proper capitalization
if [[ ! "$FIRST_LINE" =~ ^[A-Z] ]] && [[ ! "$FIRST_LINE" =~ ^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert) ]]; then
    echo -e "${YELLOW}⚠ Commit message should start with a capital letter${NC}"
fi

# Check for ending punctuation (should not end with period)
if [[ "$FIRST_LINE" =~ \.$  ]]; then
    echo -e "${YELLOW}⚠ First line should not end with a period${NC}"
fi

echo -e "${GREEN}✓ Commit message check passed${NC}"
exit 0